{
  "name": "limo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev",
    "check": "node scripts/check.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/e2e-ci.mjs",
    "test:e2e:local": "playwright test",
    "env:dev": "cp .env.development .env.local && echo 'Switched to development (local Supabase)'",
    "env:staging": "cp .env.staging .env.local && echo 'Switched to staging'",
    "env:prod": "cp .env.production .env.local && echo 'Switched to production'",
    "db:push:staging": "supabase link --project-ref xduxzpriixkxrygulgon && supabase db push --linked",
    "db:push:prod": "supabase link --project-ref mpbpzxkttsqmsaazxbkk && supabase db push --linked"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "next": "^16.1.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
